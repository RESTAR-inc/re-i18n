{
    "name": "@restar-inc/re-i18n",
    "version": "1.3.0",
    "description": "A tool to manage i18n by extracting keys from source code and generating locale files",
    "type": "module",
    "main": "lib/index.js",
    "typings": "lib/index.d.ts",
    "bin": {
        "re-i18n": "./lib/cli.js"
    },
    "files": [
        "lib"
    ],
    "scripts": {
        "build": "npm run clean && tsc -p ./tsconfig.node.json && chmod u+x ./lib/cli.js",
        "clean": "rm -rf lib",
        "format": "eslint --fix .",
        "lint": "eslint . --max-warnings 0",
        "prepare": "npm run build",
        "type-check": "tsc -p ./tsconfig.node.json --noEmit",
        "watch": "tsc -p ./tsconfig.node.json -w",
        "test": "vitest run"
    },
    "dependencies": {
        "@babel/core": "^7.29.0",
        "@babel/plugin-proposal-decorators": "^7.29.0",
        "@babel/plugin-transform-typescript": "^7.28.6",
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-typescript": "^7.28.5",
        "@babel/types": "^7.29.0",
        "@vue/compiler-sfc": "^3.5.29",
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "csv": "^6.4.1",
        "exceljs": "^4.4.0",
        "glob": "^13.0.6",
        "nunjucks": "^3.2.4",
        "prompts": "^2.4.2",
        "tslib": "^2.8.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@types/babel__core": "^7.20.5",
        "@types/node": "^24.12.0",
        "@types/nunjucks": "^3.2.6",
        "@types/prompts": "^2.4.9",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18",
        "vue": "^3.5.29"
    }
}
